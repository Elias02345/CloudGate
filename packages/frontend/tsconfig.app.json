{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "noEmit": true,
    "types": ["vite/client"],
    "rootDir": "./src"
  },
  "include": ["src/**/*", "vite.config.ts"]
}
