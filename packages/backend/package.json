{
  "name": "@cloudgate/backend",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node ./scripts/write-version.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "migrate:make": "knex --knexfile ./src/db/knexfile.ts migrate:make",
    "migrate:latest": "knex --knexfile ./src/db/knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile ./src/db/knexfile.ts migrate:rollback"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@cloudgate/shared": "workspace:*",
    "acme-client": "^5.4.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.7.0",
    "cloudflare": "^4.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.6",
    "knex": "^3.1.0",
    "liquidjs": "^10.20.1",
    "objection": "^3.1.5",
    "openai": "^4.77.0",
    "otplib": "^12.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "pino-roll": "^3.1.0",
    "qrcode": "^1.5.4",
    "tar": "^7.4.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/tar": "^6.1.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
