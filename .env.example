# CloudGate Environment Configuration
#
# IMPORTANT: ALL of these are OPTIONAL.
# If unset, CloudGate generates secure defaults at first boot and stores them in /data/secrets/.
# You do NOT need to set anything to run CloudGate — `docker run` works as-is.
#
# Use this file ONLY if you want to override defaults (e.g. bring your own keys, set a specific admin email).

# --- Bootstrap & Admin -------------------------------------------------------

# Initial admin email. Default: admin@cloudgate.local
# CLOUDGATE_INITIAL_ADMIN_EMAIL=admin@example.com

# Initial admin password. If unset, a secure 24-char random password is generated and logged to stdout
# once. You'll be forced to change it on first login.
# CLOUDGATE_INITIAL_ADMIN_PASSWORD=

# --- Secrets (auto-generated if unset) ---------------------------------------

# 32-byte base64 key for token encryption (AES-256-GCM).
# Generated to /data/secrets/encryption.key on first boot if unset.
# CLOUDGATE_ENCRYPTION_KEY=

# JWT signing secret. Generated to /data/secrets/jwt.key on first boot if unset.
# CLOUDGATE_JWT_SECRET=

# --- Database ----------------------------------------------------------------

# Default: sqlite:///data/db/db.sqlite
# CLOUDGATE_DB_URL=

# --- Logging -----------------------------------------------------------------

# CLOUDGATE_LOG_LEVEL=info
# TZ=UTC

# --- Auto-Update -------------------------------------------------------------

# Channel: stable | prerelease | nightly | disabled. Default: stable
# Initial value only — user can change later in /settings/updates UI.
# CLOUDGATE_UPDATE_CHANNEL=stable

# Mode: auto | notify | scheduled. Default: notify
# CLOUDGATE_UPDATE_MODE=notify

# Override the source repo (for forks or testing). Default: Elias02345/CloudGate
# CLOUDGATE_UPDATE_REPO=Elias02345/CloudGate

# Optional GitHub token for higher API rate limits (60 req/h anon → 5000 req/h with token).
# CLOUDGATE_GITHUB_TOKEN=

# Notbremse: set to true to fully disable the self-updater (for maintainer debugging).
# CLOUDGATE_DISABLE_UPDATES=false

# Manually force recovery UI on next boot (e.g. when DB is unreachable).
# CLOUDGATE_RECOVERY_MODE=false

# --- User/Group (LinuxServer.io-style) ---------------------------------------

# PUID=1000
# PGID=1000
